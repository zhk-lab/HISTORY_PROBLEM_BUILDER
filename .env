# Question generation agent
QUESTION_AGENT_PROVIDER=chat_completions
QUESTION_AGENT_MODEL=qwen/qwen3-4b
QUESTION_AGENT_TEMPERATURE=0.2

# Chat Completions-compatible model endpoint
QUESTION_AGENT_API_KEY=local
QUESTION_AGENT_BASE_URL=http://127.0.0.1:1234/v1/chat/completions
